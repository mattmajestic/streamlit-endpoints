# Copy this file to .env.local and update the values for your environment
# On Render, set these as environment variables in the dashboard

# Update to your deployment URL and Turso credentials
API_BASE_URL=http://localhost:8501
# Turso credentials - replace with your own values
## Free SQLite storage provider - sign up at https://turso.io/ and create a database to get these values
TURSO_DATABASE_URL=libsql://<project-user>.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your-turso-database-token
